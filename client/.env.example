# ── Path to Obsidian Vault on your HOST machine ──
# Linux / macOS : /home/you/Vault  or  /Users/you/Vault
# Windows (Docker Desktop) : /c/Users/you/Vault   (use forward slashes, /c/ instead of C:\)
TARGET_DIR=/vault

GIT_REMOTE_URL=git@github.com:username/obsidian-vault.git
GIT_USER_NAME=sbSync Client
GIT_USER_EMAIL=client@sbsync.local

# ── SSH key (host path → mounted into container) ──
# Linux / macOS : /home/you/.ssh/id_ed25519
# Windows (Docker Desktop) : /c/Users/you/.ssh/id_ed25519
SSH_KEY_HOST_PATH=/home/you/.ssh/id_ed25519
SSH_KEY_PATH=/root/.ssh/id_ed25519

PULL_INTERVAL_MINUTES=5
METRICS_PORT=8001
